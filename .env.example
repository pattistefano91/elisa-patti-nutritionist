# URL base del sito — usato da next-sitemap per generare sitemap.xml e robots.txt
# Impostare in Vercel dashboard: Settings → Environment Variables
# Lasciare vuoto per usare il default (http://localhost:3000) — il build NON fallisce se assente
SITE_URL=

# Dominio registrato su Plausible Analytics (es. elisapatti.it oppure <app>.vercel.app)
# Senza questo valore lo script Plausible NON viene caricato (nessun errore)
# Impostare in Vercel dashboard dopo aver creato il sito su plausible.io
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

# Google Places API — sincronizzazione automatica punteggio e totale recensioni
# Senza queste variabili il sito usa i valori di fallback da src/data/reviews.ts (nessun errore)
#
# Come ottenere GOOGLE_PLACES_API_KEY:
#   1. Vai su https://console.cloud.google.com
#   2. Crea un progetto (o usa uno esistente)
#   3. Abilita "Places API" dalla libreria API
#   4. Crea una credenziale API Key → restringi all'IP del server (opzionale ma consigliato)
#
# Come ottenere GOOGLE_PLACE_ID:
#   1. Vai su https://developers.google.com/maps/documentation/places/web-service/place-id
#   2. Usa il tool "Find a place" cercando "Dott.ssa Elisa Patti Biologa Nutrizionista"
#   3. Oppure cerca su Google Maps → click sul profilo → guarda l'URL (contiene il place_id)
#
GOOGLE_PLACES_API_KEY=
GOOGLE_PLACE_ID=
